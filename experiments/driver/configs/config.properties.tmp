# DB Access
database=NEO4J
database.url=bolt://neo4j:7687
database.dbName=neo4j
database.user=neo4j
database.password=12345678

#query_file=/app/resources/queries/finbench/simple_queries.cypher
#param_folder=/app/resources/params/finbench/sf_0.1/
#Query Related
query_file=/app/resources/queries/{{DATASET}}.cypher
param_folder=/app/params/{{DATASET}}/sf_{{SCALE_FACTOR}}/
param_map_file=/app/resources/param_maps/{{DATASET}}.csv
warm_up_query_count=50
test_query_count=10

# Result related
output_folder=/app/result/metrics/{{TEST_RUN}}
dataset={{DATASET}}
scale_factor={{SCALE_FACTOR}}



#sf{i}       --> test query 10 times with warm up 10
#sf{i}_{n}t  --> test sequentially (warm up n + query times n)
#sf{i}_{n}r  --> test randomly n times (warm up 50 times)